#include <stdio.h>

int main() {
    int n,i;
    int arr[50];
    int *ptr[50];

    scanf("%d",&n);

    for(i=0;i<n;i++){
        scanf("%d",&arr[i]);
        ptr[i] = &arr[i];
    }

    int max = *ptr[0], second = *ptr[0];

    for(i=1;i<n;i++){
        if(*ptr[i] > max){
            second = max;
            max = *ptr[i];
        }
        else if(*ptr[i] > second && *ptr[i] != max){
            second = *ptr[i];
        }
    }

    printf("Second largest = %d", second);
}
