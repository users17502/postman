<!DOCTYPE html>
<html>
<head>
<title>Overlapping Images</title>

<style>
body{
font-family: Arial;
text-align:center;
margin-top:40px;
}

.container{
position:relative;
width:400px;
height:250px;
margin:auto;
}

img{
width:200px;
height:150px;
position:absolute;
cursor:pointer;
transition:0.3s;
border-radius:10px;
}

.img1{ top:0; left:0; z-index:1; }
.img2{ top:30px; left:80px; z-index:2; }
.img3{ top:60px; left:160px; z-index:3; }

button{
margin:10px;
padding:8px 15px;
}
</style>

</head>

<body>

<h3>Overlapping Images</h3>

<div class="container">
<img src="https://picsum.photos/200/150?1" class="img1" onclick="bringFront(this)">
<img src="https://picsum.photos/200/150?2" class="img2" onclick="bringFront(this)">
<img src="https://picsum.photos/200/150?3" class="img3" onclick="bringFront(this)">
</div>

<script>
let z = 1;

function bringFront(element){
z++;
element.style.zIndex = z;
}
</script>

</body>
</html>
