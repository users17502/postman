#include <stdio.h>

int main() {
    int n, i;
    int arr[50];
    int *ptr[50];

    printf("Enter size: ");
    scanf("%d", &n);

    for(i=0;i<n;i++){
        scanf("%d",&arr[i]);
        ptr[i] = &arr[i];
    }

    int max = *ptr[0], min = *ptr[0];

    for(i=1;i<n;i++){
        if(*ptr[i] > max)
            max = *ptr[i];
        if(*ptr[i] < min)
            min = *ptr[i];
    }

    printf("Difference = %d", max - min);
}
